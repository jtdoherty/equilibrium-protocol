# Copy to .env and fill in. Never commit the real .env (it is gitignored).

# RPC endpoint for the target network (e.g. Arbitrum Sepolia)
SEPOLIA_RPC_URL=https://your-rpc-endpoint

# Deployer key — use a throwaway testnet key, never a key with real funds
PRIVATE_KEY=0xyour_private_key

# For contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key
